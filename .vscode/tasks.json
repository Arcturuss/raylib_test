{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Configure (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", ".",
                "-B", "build/Debug",
                "-G", "Ninja",
                "-DCMAKE_BUILD_TYPE=Debug"
            ],
            "options": {
                "env": {
                    "PATH": "C:/msys64/clang64/bin;${env:PATH}"
                }
            }
        },
        {
            "label": "CMake Build (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build/Debug"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "CMake Configure (Debug)",
            "options": {
                "env": {
                    "PATH": "C:/msys64/clang64/bin;${env:PATH}"
                }
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "CMake Configure (Release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", ".",
                "-B", "build/Release",
                "-G", "Ninja",
                "-DCMAKE_BUILD_TYPE=Release"
            ],
            "options": {
                "env": {
                    "PATH": "C:/msys64/clang64/bin;${env:PATH}"
                }
            }
        },
        {
            "label": "CMake Build (Release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build/Release"
            ],
            "group": "build",
            "dependsOn": "CMake Configure (Release)",
            "options": {
                "env": {
                    "PATH": "C:/msys64/clang64/bin;${env:PATH}"
                }
            },
            "problemMatcher": "$gcc"
        }
    ]
}