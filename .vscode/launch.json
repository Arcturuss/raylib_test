{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (LLDB)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/Debug/raylib-test.exe",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "CMake Build (Debug)",
            "stopOnEntry": false,
            "environment": [
                {
                    "name": "PATH",
                    "value": "C:/msys64/clang64/bin;${env:PATH}"
                }
            ]
        },
        {
            "name": "Debug (GDB)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/Debug/raylib-test.exe",
            "cwd": "${workspaceFolder}",
            "args": [],
            "stopAtEntry": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/clang64/bin/gdb.exe",
            "preLaunchTask": "CMake Build (Debug)",
            "environment": [
                {
                    "name": "PATH",
                    "value": "C:/msys64/clang64/bin;${env:PATH}"
                }
            ],
            "setupCommands": [
                {
                    "description": "Enable pretty printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Run (Release)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/Release/raylib-test.exe",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "CMake Build (Release)",
            "stopOnEntry": false,
            "environment": [
                {
                    "name": "PATH",
                    "value": "C:/msys64/clang64/bin;${env:PATH}"
                }
            ]
        }
    ]
}